rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && request.auth.token.email == "premiumtele009@gmail.com";
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Phase 4: Entity Validation
    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'email', 'currentBalance', 'createdAt', 'updatedAt', 'phone'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 200
        && data.phone is string && data.phone.size() <= 20
        && data.currentBalance is number && data.currentBalance >= 0
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['agentName', 'customerPhone', 'items', 'totalAmount', 'totalPoints', 'status', 'timestamp', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 9 && data.keys().size() <= 10
        && data.agentName is string && data.agentName.size() <= 100
        && data.customerPhone is string && data.customerPhone.size() <= 20
        && data.items is list
        && data.totalAmount is number
        && data.totalPoints is number
        && data.status in ['pending', 'success', 'failed']
        && data.timestamp is timestamp
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && (!data.keys().contains('linkedTopupId') || data.linkedTopupId is string);
    }

    function isValidTopUp(data) {
      return data.keys().hasAll(['agentName', 'customerName', 'topUpNumber', 'tariff', 'amount', 'points', 'renewDate', 'period', 'expiryDate', 'status', 'timestamp', 'createdAt', 'updatedAt', 'paymentMethod', 'customerId', 'contact'])
        && data.keys().size() == 16
        && data.agentName is string && data.agentName.size() <= 100
        && data.customerName is string && data.customerName.size() <= 100
        && data.topUpNumber is string && data.topUpNumber.size() <= 50
        && data.tariff is string && data.tariff.size() <= 100
        && data.amount is number && data.amount >= 0
        && data.points is number
        && data.renewDate is timestamp
        && data.period is number && data.period >= 0
        && data.expiryDate is timestamp
        && data.status in ['pending', 'success', 'failed']
        && data.paymentMethod is string
        && data.timestamp is timestamp
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && data.customerId is string
        && data.contact is string;
    }

    // 1. Customers Collection
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidCustomer(incoming());
      allow update: if isVerified() && (
        isValidCustomer(incoming()) 
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasAny(['name', 'email', 'phone', 'currentBalance', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    // 2. Sales Collection
    match /sales/{saleId} {
      allow read: if isVerified() && (isAdmin() || resource.data.agentName == request.auth.token.name);
      allow create: if isVerified() && isValidSale(incoming()) && (isAdmin() || incoming().agentName == request.auth.token.name);
      allow update: if isVerified() && (isAdmin() || resource.data.agentName == request.auth.token.name);
      allow delete: if isAdmin() || (isVerified() && resource.data.agentName == request.auth.token.name);
    }

    // 3. Topups Collection
    match /topups/{topupId} {
      allow read: if isVerified() && (isAdmin() || resource.data.agentName == request.auth.token.name);
      allow create: if isVerified() && isValidTopUp(incoming()) && (isAdmin() || incoming().agentName == request.auth.token.name);
      allow delete: if isAdmin() || (isVerified() && resource.data.agentName == request.auth.token.name);
    }
  }
}
